default:
    @just --list

# Run all tests
test:
    cargo test --all

# Check formatting
fmt:
    cargo fmt --all --check

# Auto-format code
fmt-fix:
    cargo fmt --all

# Run clippy lints
lint:
    cargo clippy --all-targets --all-features -- -D warnings

# Build and open the mdbook
book:
    cd avm-book && mdbook serve --open

# Build book for CI
book-build:
    cd avm-book && mdbook build

# Run only integration tests
test-examples:
    cargo test -p avm-examples

# Generate and open rustdoc
doc:
    cargo doc --open -p avm-core

# Run all checks (fmt + lint + test)
check: fmt lint test

# Build the avm-node binary
build-node:
    cargo build -p avm-node

# Run distributed demo — Terminal 1 (start this first)
demo-beta:
    RUST_LOG=info cargo run -p avm-node -- --name beta --port 9002 --peer alpha:9001 --demo

# Run distributed demo — Terminal 2
demo-alpha:
    RUST_LOG=info cargo run -p avm-node -- --name alpha --port 9001 --peer beta:9002 --demo --rounds 3
